generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ──────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

enum PostStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

enum ContactStatus {
  PENDING
  READ
  REPLIED
  ARCHIVED
}

// ─── User ───────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  password  String
  name      String
  role      Role     @default(USER)
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  // Client-specific fields (only used when role = USER)
  phone      String?
  birthDate  DateTime? @map("birth_date")
  startedAt  DateTime? @map("started_at")  // coaching start date
  monthlyFee Int?      @map("monthly_fee") // cents EUR
  notes      String?   @default("")        // internal, admin-only
  heightCm   Int?      @map("height_cm")   // client height in cm, used for BMI
  allowedAreas Json?   @map("allowed_areas") // per-user access override; null = use default behavior

  posts Post[] @relation("PostAuthor")

  // Client relations (coach-managed content)
  workouts         Workout[]
  tasks            ClientTask[]
  documents        ClientDocument[]
  diets            Diet[]
  invoices         Invoice[]
  checkIns         ClientCheckIn[]
  assignedRecipes  ClientRecipe[]

  @@map("users")
}

// ─── Post ───────────────────────────────────────────

model Post {
  id          String     @id @default(cuid())
  title       String
  slug        String     @unique
  excerpt     String?
  content     String
  status      PostStatus @default(DRAFT)
  publishedAt DateTime?  @map("published_at")
  createdAt   DateTime   @default(now()) @map("created_at")
  updatedAt   DateTime   @updatedAt @map("updated_at")

  authorId String @map("author_id")
  author   User   @relation("PostAuthor", fields: [authorId], references: [id], onDelete: Restrict)

  coverId String? @unique @map("cover_id")
  cover   Image?  @relation("PostCover", fields: [coverId], references: [id], onDelete: SetNull)

  images Image[] @relation("PostGallery")

  @@index([status, publishedAt])
  @@index([authorId])
  @@map("posts")
}

// ─── Image ──────────────────────────────────────────

model Image {
  id        String   @id @default(cuid())
  url       String
  key       String   @unique // storage key (S3, Cloudinary, etc.)
  alt       String   @default("")
  width     Int?
  height    Int?
  size      Int? // bytes
  mime      String   @default("image/jpeg")
  gallery   Boolean  @default(false) // true = appears in landing gallery
  order     Int      @default(0) // sort order for gallery
  createdAt DateTime @default(now()) @map("created_at")

  coverOf Post? @relation("PostCover")

  postId String? @map("post_id")
  post   Post?   @relation("PostGallery", fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([gallery, order])
  @@map("images")
}

// ─── PageView ──────────────────────────────────────

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String   @default("")
  userAgent String   @default("") @map("user_agent")
  ip        String   @default("")
  country   String   @default("")
  city      String   @default("")
  device    String   @default("") // desktop, mobile, tablet
  browser   String   @default("")
  os        String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([createdAt])
  @@index([path])
  @@map("page_views")
}

// ─── Site Config (key-value store for landing page) ─

model SiteConfig {
  key       String   @id
  value     Json
  updatedAt DateTime @updatedAt @map("updated_at")

  @@map("site_config")
}

// ─── Subscriber ─────────────────────────────────────

model Subscriber {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String    @default("")
  active        Boolean   @default(true)
  confirmedAt   DateTime? @map("confirmed_at")
  unsubscribedAt DateTime? @map("unsubscribed_at")
  createdAt     DateTime  @default(now()) @map("created_at")

  @@index([active])
  @@index([createdAt])
  @@map("subscribers")
}

// ─── Newsletter Campaign ────────────────────────────

enum CampaignStatus {
  DRAFT
  SENT
}

model Campaign {
  id         String         @id @default(cuid())
  subject    String
  content    String         // HTML body
  template   String         @default("custom") // "new_post" | "custom"
  postId     String?        @map("post_id")
  status     CampaignStatus @default(DRAFT)
  sentAt     DateTime?      @map("sent_at")
  sentCount  Int            @default(0) @map("sent_count")
  createdAt  DateTime       @default(now()) @map("created_at")
  updatedAt  DateTime       @updatedAt @map("updated_at")

  @@index([status])
  @@index([createdAt])
  @@map("campaigns")
}

// ─── Booking Link ───────────────────────────────────

model BookingLink {
  id          String    @id @default(cuid())
  slug        String    @unique
  title       String    @default("Reserva tu cita")
  description String    @default("")
  duration    Int       @default(60) // minutes per session
  active      Boolean   @default(true)
  expiresAt   DateTime? @map("expires_at")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  bookings Booking[]

  @@index([active])
  @@index([expiresAt])
  @@map("booking_links")
}

// ─── Booking ────────────────────────────────────────

enum BookingStatus {
  PENDING
  CONFIRMED
  CANCELLED
}

model Booking {
  id        String        @id @default(cuid())
  date      DateTime      // Date + time of booking
  duration  Int           @default(60) // minutes
  name      String
  email     String
  phone     String        @default("")
  notes     String        @default("")
  status    BookingStatus @default(CONFIRMED)
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  linkId String      @map("link_id")
  link   BookingLink @relation(fields: [linkId], references: [id], onDelete: Cascade)

  @@index([linkId])
  @@index([date])
  @@index([status])
  @@index([email])
  @@map("bookings")
}

// ─── Availability ───────────────────────────────────

model Availability {
  id        String   @id @default(cuid())
  dayOfWeek Int      // 0=Sunday, 1=Monday ... 6=Saturday
  startTime String   // "HH:mm" (e.g. "15:00")
  endTime   String   // "HH:mm" (e.g. "21:00")
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")

  @@unique([dayOfWeek])
  @@index([active])
  @@map("availability")
}

// ─── Event Page (Landing Builder) ───────────────────

enum EventPageStatus {
  DRAFT
  PUBLISHED
  ARCHIVED
}

model EventPage {
  id          String          @id @default(cuid())
  slug        String          @unique
  title       String
  description String          @default("")
  status      EventPageStatus @default(DRAFT)
  template    String          @default("custom") // "webinar" | "fitness" | "coaching" | "custom"
  createdAt   DateTime        @default(now()) @map("created_at")
  updatedAt   DateTime        @updatedAt @map("updated_at")

  blocks EventBlock[]
  leads  EventLead[]

  @@index([status])
  @@index([slug])
  @@map("event_pages")
}

model EventBlock {
  id      String @id @default(cuid())
  type    String // "hero" | "text" | "image" | "cta" | "gallery" | "form" | "countdown" | "faq"
  data    Json   // block-specific content
  order   Int    @default(0)

  pageId String    @map("page_id")
  page   EventPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId, order])
  @@map("event_blocks")
}

model EventLead {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String   @default("")
  message   String   @default("")
  createdAt DateTime @default(now()) @map("created_at")

  pageId String    @map("page_id")
  page   EventPage @relation(fields: [pageId], references: [id], onDelete: Cascade)

  @@index([pageId])
  @@index([email])
  @@index([createdAt])
  @@map("event_leads")
}

// ─── Knowledge Base ─────────────────────────────────

model KbArticle {
  id         String   @id // matches static article key e.g. "getting-started/welcome"
  categoryId String   @map("category_id") // e.g. "getting-started"
  title      String
  content    String   // HTML
  sortOrder  Int      @default(0) @map("sort_order")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([categoryId, sortOrder])
  @@map("kb_articles")
}

model KbCategory {
  id          String   @id // e.g. "getting-started"
  label       String
  icon        String   @default("📄")
  description String   @default("")
  sortOrder   Int      @default(0) @map("sort_order")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([sortOrder])
  @@map("kb_categories")
}

// ─── Contact ────────────────────────────────────────

model Contact {
  id        String        @id @default(cuid())
  name      String
  email     String
  phone     String?
  subject   String
  message   String
  status    ContactStatus @default(PENDING)
  readAt    DateTime?     @map("read_at")
  repliedAt DateTime?     @map("replied_at")
  createdAt DateTime      @default(now()) @map("created_at")

  @@index([status])
  @@index([createdAt])
  @@map("contacts")
}

// ─── Client coaching area ───────────────────────────

enum WorkoutStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

model Workout {
  id          String        @id @default(cuid())
  clientId    String        @map("client_id")
  client      User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String        @default("")
  status      WorkoutStatus @default(ACTIVE)
  weekDay     Int?          @map("week_day") // 0-6, null = general
  exercises   Json          // [{ name, sets, reps, weight, restSec, notes, completed }]
  sortOrder   Int           @default(0) @map("sort_order")
  createdAt   DateTime      @default(now()) @map("created_at")
  updatedAt   DateTime      @updatedAt @map("updated_at")

  @@index([clientId, status])
  @@map("workouts")
}

enum TaskCategory {
  DAILY
  WEEKLY
  GENERAL
}

model ClientTask {
  id          String       @id @default(cuid())
  clientId    String       @map("client_id")
  client      User         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String       @default("")
  completed   Boolean      @default(false)
  completedAt DateTime?    @map("completed_at")
  category    TaskCategory @default(GENERAL)
  dueDate     DateTime?    @map("due_date")
  sortOrder   Int          @default(0) @map("sort_order")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")

  @@index([clientId, completed])
  @@map("client_tasks")
}

enum DocumentUploader {
  COACH
  CLIENT
}

model ClientDocument {
  id          String           @id @default(cuid())
  clientId    String           @map("client_id")
  client      User             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String           @default("")
  fileUrl     String           @map("file_url")
  fileKey     String           @map("file_key")
  fileSize    Int              @map("file_size")
  fileMime    String           @map("file_mime")
  uploadedBy  DocumentUploader @default(COACH) @map("uploaded_by")
  createdAt   DateTime         @default(now()) @map("created_at")

  @@index([clientId])
  @@map("client_documents")
}

model Diet {
  id          String    @id @default(cuid())
  clientId    String    @map("client_id")
  client      User      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  title       String
  description String    @default("")
  startDate   DateTime? @map("start_date")
  endDate     DateTime? @map("end_date")
  active      Boolean   @default(true)
  meals       Json      // [{ name, time, foods: [{ name, grams, calories, protein, carbs, fat }] }]
  notes       String    @default("")
  createdAt   DateTime  @default(now()) @map("created_at")
  updatedAt   DateTime  @updatedAt @map("updated_at")

  @@index([clientId, active])
  @@map("diets")
}

enum InvoiceStatus {
  DRAFT
  PENDING
  PAID
  CANCELLED
  OVERDUE
}

model Invoice {
  id        String        @id @default(cuid())
  clientId  String        @map("client_id")
  client    User          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  number    String        @unique // e.g. "2026-001"
  concept   String
  amount    Int           // cents EUR
  currency  String        @default("EUR")
  status    InvoiceStatus @default(PENDING)
  issueDate DateTime      @default(now()) @map("issue_date")
  dueDate   DateTime?     @map("due_date")
  paidAt    DateTime?     @map("paid_at")
  pdfUrl    String?       @map("pdf_url")
  notes     String        @default("")
  createdAt DateTime      @default(now()) @map("created_at")
  updatedAt DateTime      @updatedAt @map("updated_at")

  @@index([clientId, status])
  @@index([status, dueDate])
  @@map("invoices")
}

// ─── Templates (reusable content for the coach) ─────

model WorkoutTemplate {
  id          String   @id @default(cuid())
  name        String   // "Perdida de peso — Dia 1"
  description String   @default("")
  category    String   @default("general") // "perdida-peso" | "masa-muscular" | "competicion" | "general"
  weekDay     Int?     @map("week_day")    // 0-6, null = general
  exercises   Json     // same shape as Workout.exercises
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category, sortOrder])
  @@map("workout_templates")
}

model DietTemplate {
  id          String   @id @default(cuid())
  name        String   // "Definicion 2500 kcal"
  description String   @default("")
  category    String   @default("general") // "perdida-peso" | "volumen" | "mantenimiento" | "general"
  meals       Json     // same shape as Diet.meals
  notes       String   @default("")
  sortOrder   Int      @default(0) @map("sort_order")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  @@index([category, sortOrder])
  @@map("diet_templates")
}

// ─── Client weekly check-ins (progress tracking) ───

model ClientCheckIn {
  id        String   @id @default(cuid())
  clientId  String   @map("client_id")
  client    User     @relation(fields: [clientId], references: [id], onDelete: Cascade)

  date      DateTime                     // Date of the check-in (client-chosen, usually weekly)
  weightKg  Float?   @map("weight_kg")   // Weight in kg (supports decimals — 72.3)

  photoFrontUrl String? @map("photo_front_url")
  photoFrontKey String? @map("photo_front_key")
  photoSideUrl  String? @map("photo_side_url")
  photoSideKey  String? @map("photo_side_key")
  photoBackUrl  String? @map("photo_back_url")
  photoBackKey  String? @map("photo_back_key")

  notes     String   @default("")        // How the client felt / what they noticed
  createdAt DateTime @default(now()) @map("created_at")

  @@index([clientId, date])
  @@map("client_checkins")
}

// ─── Recipes (AI-generated + manually created, for reuse) ───

model Recipe {
  id          String   @id @default(cuid())
  title       String
  description String   @default("")
  category    String   @default("general") // "desayuno" | "comida" | "cena" | "snack" | "general"
  servings    Int      @default(1)
  prepTimeMin Int?     @map("prep_time_min")
  cookTimeMin Int?     @map("cook_time_min")
  allergens   Json     @default("[]")     // string[] — e.g. ["gluten", "lactosa"]
  ingredients Json                         // [{ name, grams?, unit?, notes? }]
  steps       Json                         // string[] — preparation steps in order
  macros      Json     @default("{}")     // { calories, protein, carbs, fat } per serving
  aiGenerated Boolean  @default(false) @map("ai_generated")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  assignedClients ClientRecipe[]

  @@index([category, createdAt])
  @@map("recipes")
}

// ─── Recipe assignments (link recipes to clients) ───

model ClientRecipe {
  id         String   @id @default(cuid())
  clientId   String   @map("client_id")
  recipeId   String   @map("recipe_id")
  assignedAt DateTime @default(now()) @map("assigned_at")

  client User   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  recipe Recipe @relation(fields: [recipeId], references: [id], onDelete: Cascade)

  @@unique([clientId, recipeId])
  @@index([clientId])
  @@map("client_recipes")
}
